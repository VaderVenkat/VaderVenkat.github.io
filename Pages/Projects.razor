@page "/projects"

<PageTitle>Projects — Venkateshan K.S</PageTitle>

<section class="page-hero">
    <div class="container">
        <span class="section-tag">Portfolio</span>
        <h1 class="page-title">My Projects</h1>
        <p class="page-subtitle">Game prototypes built with Unity & C#</p>
    </div>
</section>

<section class="section">
    <div class="container">

        <!-- Project 1: War of the Worlds -->
        <div class="project-detail-card">
            <div class="project-detail-img">
                <img src="images/war-of-worlds.png" alt="War of the Worlds Screenshot" />
                <div class="project-platform-tags">
                    <span class="platform-tag">Console</span>
                </div>
            </div>
            <div class="project-detail-info">
                <div class="project-header">
                    <div>
                        <span class="project-num">01</span>
                        <h2 class="project-name">War of the Worlds</h2>
                        <span class="project-date">Nov 2024 – Dec 2024</span>
                    </div>
                    <a href="https://vadervenkat.itch.io/war-of-the-worlds" target="_blank" class="btn-outline">
                        Play on Itch.io ↗
                    </a>
                </div>
                <p class="project-description">
                    A 3D game prototype showcasing essential game development skills for console and mobile platforms.
                    This project demonstrates my ability to build functional game systems from the ground up, focusing
                    on AI behaviour, physics interactions, and player-friendly UI design.
                </p>
                <div class="project-highlights">
                    <h4>Key Highlights</h4>
                    <ul class="highlight-list">
                        <li>
                            <span class="highlight-dot"></span>
                            Implemented game physics for realistic object interactions
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Designed engaging game environment using basic shapes, materials, and colors
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Built AI navigation systems and collision mechanics for enhanced gameplay dynamics
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Utilized Unity UI tools and Unity GUI for intuitive player interfaces
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Leveraged Unity API and C# scripting to manage game logic and mechanics
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Integrated Input Manager and Transform components for seamless player control
                        </li>
                    </ul>
                </div>
                <div class="tech-stack-used">
                    <span class="tech-chip">C#</span>
                    <span class="tech-chip">Unity 3D</span>
                    <span class="tech-chip">Unity API</span>
                    <span class="tech-chip">Unity UI</span>
                    <span class="tech-chip">AI Navigation</span>
                    <span class="tech-chip">Input Manager</span>
                </div>
            </div>
        </div>

        <div class="project-divider"></div>

        <!-- Project 2: Pandora -->
        <div class="project-detail-card reverse" id="pandora">
            <div class="project-detail-img">
                <img src="images/pandora.png" alt="Pandora Screenshot" />
                <div class="project-platform-tags">
                    <span class="platform-tag">Console</span>
                    <span class="platform-tag">PC</span>
                </div>
            </div>
            <div class="project-detail-info">
                <div class="project-header">
                    <div>
                        <span class="project-num">02</span>
                        <h2 class="project-name">Pandora</h2>
                        <span class="project-date">Jul 2025 – Aug 2025</span>
                    </div>
                    <a href="https://vadervenkat.itch.io/pandora" target="_blank" class="btn-outline">
                        Play on Itch.io ↗
                    </a>
                </div>
                <p class="project-description">
                    Developed as part of my learning journey in Unity to strengthen core game development skills.
                    Pandora focuses on creating a unique gameplay experience while building custom technical systems
                    without relying on Unity's built-in AI tools — demonstrating deeper programming capability.
                </p>
                <div class="project-highlights">
                    <h4>Key Highlights</h4>
                    <ul class="highlight-list">
                        <li>
                            <span class="highlight-dot"></span>
                            Designed enemy behavior without Unity AI NavMesh — built custom chase logic from scratch
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Created a camera control system with input support for both keyboard and controller
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Built a custom input system for smooth player control and gameplay flexibility
                        </li>
                        <li>
                            <span class="highlight-dot"></span>
                            Modeled 3D trees and applied textures to enrich the game environment
                        </li>
                    </ul>
                </div>
                <div class="tech-stack-used">
                    <span class="tech-chip">C#</span>
                    <span class="tech-chip">Unity 3D</span>
                    <span class="tech-chip">Unity API</span>
                    <span class="tech-chip">Unity UI</span>
                    <span class="tech-chip">Custom AI Logic</span>
                    <span class="tech-chip">3D Modeling</span>
                </div>
            </div>
        </div>

    </div>
</section>
