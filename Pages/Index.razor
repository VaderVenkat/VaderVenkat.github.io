@page "/"

<PageTitle>Venkateshan K.S — Unity Game Developer</PageTitle>

<!-- HERO SECTION -->
<section class="hero">
    <div class="hero-bg">
        <svg class="hero-svg" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
            <!-- Abstract game-themed minimal SVG art -->
            <circle cx="650" cy="100" r="80" fill="none" stroke="#E84545" stroke-width="1.5" opacity="0.15"/>
            <circle cx="650" cy="100" r="50" fill="none" stroke="#E84545" stroke-width="1" opacity="0.2"/>
            <circle cx="650" cy="100" r="20" fill="#E84545" opacity="0.08"/>
            <!-- Grid lines -->
            <line x1="0" y1="150" x2="800" y2="150" stroke="#E84545" stroke-width="0.5" opacity="0.08"/>
            <line x1="0" y1="300" x2="800" y2="300" stroke="#E84545" stroke-width="0.5" opacity="0.08"/>
            <line x1="0" y1="450" x2="800" y2="450" stroke="#E84545" stroke-width="0.5" opacity="0.08"/>
            <line x1="150" y1="0" x2="150" y2="600" stroke="#E84545" stroke-width="0.5" opacity="0.08"/>
            <line x1="400" y1="0" x2="400" y2="600" stroke="#E84545" stroke-width="0.5" opacity="0.08"/>
            <line x1="650" y1="0" x2="650" y2="600" stroke="#E84545" stroke-width="0.5" opacity="0.08"/>
            <!-- Game controller outline -->
            <g transform="translate(80, 420)" opacity="0.08">
                <rect x="0" y="20" width="120" height="70" rx="35" fill="none" stroke="#E84545" stroke-width="2"/>
                <circle cx="85" cy="40" r="6" fill="none" stroke="#E84545" stroke-width="2"/>
                <circle cx="100" cy="55" r="6" fill="none" stroke="#E84545" stroke-width="2"/>
                <circle cx="70" cy="55" r="6" fill="none" stroke="#E84545" stroke-width="2"/>
                <circle cx="85" cy="70" r="6" fill="none" stroke="#E84545" stroke-width="2"/>
                <rect x="25" y="50" width="20" height="6" rx="3" fill="#E84545"/>
                <rect x="31" y="44" width="6" height="20" rx="3" fill="#E84545"/>
            </g>
            <!-- Small dots scattered -->
            <circle cx="200" cy="80" r="3" fill="#E84545" opacity="0.15"/>
            <circle cx="350" cy="200" r="2" fill="#E84545" opacity="0.12"/>
            <circle cx="500" cy="350" r="4" fill="#E84545" opacity="0.1"/>
            <circle cx="100" cy="300" r="2" fill="#E84545" opacity="0.15"/>
            <circle cx="720" cy="400" r="3" fill="#E84545" opacity="0.12"/>
            <!-- Diamond shapes -->
            <polygon points="300,50 315,65 300,80 285,65" fill="none" stroke="#E84545" stroke-width="1.5" opacity="0.12"/>
            <polygon points="550,500 560,510 550,520 540,510" fill="none" stroke="#E84545" stroke-width="1" opacity="0.1"/>
        </svg>
    </div>

    <div class="hero-content">
        <div class="hero-tag animate-fade-in">
            <span class="tag-dot"></span>
            <span>Available for opportunities</span>
        </div>
        <h1 class="hero-title animate-slide-up">
            Venkateshan<br />
            <span class="accent-text">K.S</span>
        </h1>
        <p class="hero-subtitle animate-slide-up delay-1">Unity Game Developer</p>
        <p class="hero-desc animate-slide-up delay-2">
            Crafting immersive game experiences with <strong>Unity & C#</strong>.<br />
            Chennai, Tamil Nadu, India.
        </p>
        <div class="hero-cta animate-slide-up delay-3">
            <a href="/projects" class="btn-primary">View Projects</a>
            <a href="/contact" class="btn-secondary">Get In Touch</a>
        </div>

        <!-- Tech Stack Pills -->
        <div class="tech-pills animate-fade-in delay-4">
            <span class="pill">Unity</span>
            <span class="pill">C#</span>
            <span class="pill">.NET</span>
            <span class="pill">Blender</span>
            <span class="pill">3D Dev</span>
        </div>
    </div>

    <div class="hero-scroll">
        <span>Scroll</span>
        <div class="scroll-line"></div>
    </div>
</section>

<!-- QUICK STATS -->
<section class="stats-section">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <h3 class="stat-number">2+</h3>
                <p class="stat-label">Game Projects</p>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <h3 class="stat-number">3+</h3>
                <p class="stat-label">Years of Learning</p>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <h3 class="stat-number">2+</h3>
                <p class="stat-label">Languages Known</p>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <h3 class="stat-number">1</h3>
                <p class="stat-label">Award Won</p>
            </div>
        </div>
    </div>
</section>

<!-- FEATURED PROJECTS PREVIEW -->
<section class="section featured-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Work</span>
            <h2 class="section-title">Featured Projects</h2>
        </div>
        <!-- war of the world  -->
        <div class="featured-grid">
            <div class="featured-card">
                <div class="card-img-wrap">
                    <img src="images/war-of-worlds.png" alt="War of the Worlds game screenshot" class="card-img" />
                    <div class="card-img-overlay">
                        <a href="/projects#war-of-worlds" class="overlay-btn">View Details</a>
                    </div>
                </div>
                <div class="card-body">
                    <span class="card-tag">Unity 3D · AI Navigation</span>
                    <h3 class="card-title">War of the Worlds</h3>
                    <p class="card-desc">3D game prototype with AI navigation, physics, and immersive environment design.</p>
                    <div class="card-meta">
                        <span>Nov 2024 – Dec 2024</span>
                        <a href="/projects#war-of-worlds" class="card-link">Explore →</a>
                    </div>
                </div>
            </div>
              
<!-- pandora card  -->
            <div class="featured-card">
                <div class="card-img-wrap">
                    <img src="images/pandora.png" alt="Pandora game screenshot" class="card-img" />
                    <div class="card-img-overlay">
                       <a href="/projects#pandora" class="overlay-btn">View Details</a>
                    </div>
                </div>
                <div class="card-body">
                    <span class="card-tag">Unity 3D · Custom AI</span>
                    <h3 class="card-title">Pandora</h3>
                    <p class="card-desc">Custom enemy AI logic, camera systems, 3D modeling and controller support.</p>
                    <div class="card-meta">
                        <span>Jul 2025 – Aug 2025</span>
                        <a href="/projects#pandora" class="card-link">Explore →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="cta-section">
    <div class="container">
        <div class="cta-box">
            <div class="cta-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
            </div>
            <h2>Let's work together</h2>
            <p>Looking for a passionate Unity developer? I'm open to full-time roles, freelance, and collaborations.</p>
            <a href="/contact" class="btn-primary">Say Hello</a>
        </div>
    </div>
</section>
