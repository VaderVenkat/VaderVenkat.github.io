@page "/awards"

<PageTitle>Awards — Venkateshan K.S</PageTitle>

<section class="page-hero">
    <div class="container">
        <span class="section-tag">Recognition</span>
        <h1 class="page-title">Awards</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="award-feature-card">
            <div class="award-img-col">
                <div class="award-img-wrap">
                    <img src="images/q-pioneer.jpg" alt="Q Pioneer Certificate of Appreciation from Daimler India" />
                </div>
                <div class="award-img-caption">Certificate of Appreciation — Daimler India</div>
            </div>
            <div class="award-info-col">
                <div class="award-badge-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                        <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
                    </svg>
                </div>
                <span class="award-year">02 February 2023</span>
                <h2 class="award-title">"Q" Pioneer</h2>
                <h3 class="award-org">Daimler India Commercial Vehicles Pvt. Ltd.</h3>
                <div class="award-divider"></div>
                <p class="award-description">
                    Awarded the <strong>"Q" Pioneer</strong> Certificate of Appreciation by Daimler India Commercial Vehicles
                    in recognition of exceptional commitment in detecting quality issues and providing a pioneering spirit
                    with regards to customer orientation.
                </p>
                <p class="award-description">
                    This award was presented under the Quality Excellence Transformation (QET) — Cultural Enrichment program,
                    reflecting dedication to maintaining the highest standards of product quality across Daimler's
                    bus and truck manufacturing lines.
                </p>
                <div class="award-tags">
                    <span class="award-tag-pill">Quality Excellence</span>
                    <span class="award-tag-pill">Customer Orientation</span>
                    <span class="award-tag-pill">Daimler India</span>
                    <span class="award-tag-pill">QET Program</span>
                </div>
            </div>
        </div>
    </div>
</section>
