@page "/skills"

<PageTitle>Skills — Venkateshan K.S</PageTitle>

<section class="page-hero">
    <div class="container">
        <span class="section-tag">Expertise</span>
        <h1 class="page-title">Skills & Tools</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="skills-layout">

            <!-- Programming -->
            <div class="skill-group">
                <div class="skill-group-header">
                    <div class="skill-group-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                        </svg>
                    </div>
                    <h3>Programming</h3>
                </div>
                <div class="skill-bars">
                    <SkillBar Name="C#" Level="90" />
                    <SkillBar Name="Python" Level="70" />
                    <SkillBar Name="JavaScript" Level="65" />
                    <SkillBar Name="C++" Level="60" />
                    <SkillBar Name="Java" Level="65" />
                </div>
            </div>

            <!-- Game Dev Tools -->
            <div class="skill-group">
                <div class="skill-group-header">
                    <div class="skill-group-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                            <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                        </svg>
                    </div>
                    <h3>Game Development</h3>
                </div>
                <div class="skill-bars">
                    <SkillBar Name="Unity Engine" Level="85" />
                    <SkillBar Name="Unity API & C# Scripting" Level="80" />
                    <SkillBar Name="AI Navigation (NavMesh)" Level="75" />
                    <SkillBar Name="Game Physics" Level="75" />
                    <SkillBar Name="Unity UI / GUI" Level="80" />
                </div>
            </div>

            <!-- 3D & Design -->
            <div class="skill-group">
                <div class="skill-group-header">
                    <div class="skill-group-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                        </svg>
                    </div>
                    <h3>3D & Design</h3>
                </div>
                <div class="skill-bars">
                    <SkillBar Name="Blender (3D Modeling)" Level="65" />
                    <SkillBar Name="Texturing" Level="60" />
                    <SkillBar Name="Game Environment Design" Level="70" />
                </div>
            </div>

            

        </div>
    </div>
</section>

<!-- Currently Learning -->
<section class="section bg-light-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Growth</span>
            <h2 class="section-title">Currently Learning</h2>
        </div>
        <div class="learning-grid">
            <div class="learning-card">
                <div class="learning-icon">🎮</div>
                <h4>Shader Graph</h4>
                <p>Visual shader authoring for Unity</p>
            </div>
            <div class="learning-card">
                <div class="learning-icon">🥽</div>
                <h4>VR Development</h4>
                <p>Exploring XR Toolkit in Unity</p>
            </div>
            <div class="learning-card">
                <div class="learning-icon">📱</div>
                <h4>Mobile Optimization</h4>
                <p>Optimizing games for Android/iOS</p>
            </div>
            <div class="learning-card">
                <div class="learning-icon">🌐</div>
                <h4>Blazor & .NET</h4>
                <p>Web development with C# ecosystem</p>
            </div>
        </div>
    </div>
</section>
