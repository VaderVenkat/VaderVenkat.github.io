@page "/resume"
@inject NavigationManager Nav

<PageTitle>Resume — Venkateshan K.S</PageTitle>

<section class="page-hero">
    <div class="container">
        <span class="section-tag">CV</span>
        <h1 class="page-title">Resume</h1>
    </div>
</section>

<section class="section">
    <div class="container" style="text-align:center; max-width:600px; margin:auto;">
        <div class="resume-download-card">
            <div class="resume-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="60" height="60">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
            </div>
            <h2>Venkateshan K.S — Resume</h2>
            <p>Unity Game Developer · Chennai, Tamil Nadu</p>
            <p class="resume-updated">Last updated: February 2026</p>
            <a href="https://vadervenkat.github.io/resume/VenkateshanKS_CV.pdf" target="_blank" class="btn-primary" style="display:inline-flex;align-items:center;gap:10px;font-size:1rem;padding:1rem 2rem;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Download PDF
            </a>
        </div>
    </div>
</section>
