            </div>

            <!-- Contact Form -->
            <div class="contact-form-col">
                <div class="contact-form-card">
                    <h3>Send a Message</h3>
                    <div class="form-group">
                        <label>Your Name</label>
                        <input type="text" @bind="formName" placeholder="e.g. John Doe" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Your Email</label>
                        <input type="email" @bind="formEmail" placeholder="e.g. john@email.com" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Subject</label>
                        <input type="text" @bind="formSubject" placeholder="e.g. Game Developer Opportunity" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Message</label>
                        <textarea @bind="formMessage" placeholder="Your message here..." class="form-textarea" rows="5"></textarea>
                    </div>
                    <a href="@GetMailtoLink()" class="btn-primary" style="display:block;text-align:center;">
                        Send via Email
                    </a>
                    <p class="form-note">This will open your email client with the message prefilled.</p>
                </div>
            </div>

        </div>
    </div>
</section>

@code {
    private string formName = "";
    private string formEmail = "";
    private string formSubject = "";
    private string formMessage = "";

    private string GetMailtoLink()
    {
        var subject = Uri.EscapeDataString(string.IsNullOrEmpty(formSubject) ? "Hello from your website" : formSubject);
        var body = Uri.EscapeDataString(
            $"Hi Venkateshan,\n\n{formMessage}\n\nFrom: {formName}\nEmail: {formEmail}"
        );
        return $"mailto:venkateshanramasamy2001@gmail.com?subject={subject}&body={body}";
    }
}
